# --- Infrastructure ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=payment_db
POSTGRES_DSN=postgres://user:password@localhost:5432/payment_db?sslmode=disable

REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9092

# --- App Settings ---
LOG_LEVEL=debug
JWT_SECRET=your-very-secret-key-here

# --- Service Addresses (Local Dev) ---
