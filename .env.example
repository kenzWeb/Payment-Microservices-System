INVENTORY_ADDR=localhost:50052
ORDER_ADDR=localhost:50053

# --- Ports ---
HTTP_PORT=8080
GRPC_PORT_AUTH=50051
GRPC_PORT_INVENTORY=50052
GRPC_PORT_ORDER=50053
